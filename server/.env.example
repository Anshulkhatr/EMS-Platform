# Server environment variables (copy to .env for local dev, set in Render dashboard for production)

PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/ems_db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=24h

# Brevo SMTP (Render-friendly — avoids Gmail port blocks)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=your-verified-sender@yourdomain.com

# Optional: Redis (not required for email)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Optional: AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
